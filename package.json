{
  "name": "@fastaar/nextjs",
  "version": "0.1.4",
  "description": "Next.js React Server Components & Route Handlers integration for Fastaar payment gateway",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastaar/fastaar-nextjs.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "fastaar",
    "bkash",
    "nagad",
    "payments",
    "bangladesh",
    "nextjs",
    "server-components",
    "react-server-components"
  ]
}
